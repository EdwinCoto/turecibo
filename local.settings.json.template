{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "TELEGRAM_BOT_TOKEN": "<your-bot-token-from-botfather>",
    "TELEGRAM_WEBHOOK_SECRET": "<random-secret-string>",
    "TELEGRAM_ALLOWED_USER_IDS": "<comma-separated-user-ids>",
    "TELEGRAM_ALLOWED_CHAT_IDS": "<comma-separated-chat-ids>",
    "OPENAI_API_KEY": "<your-openai-key-or-github-models-token>",
    "OPENAI_MODEL": "openai/gpt-4.1",
    "AzureFunctionsJobHost__logging__console__isEnabled": "true",
    "AzureFunctionsJobHost__logging__logLevel__default": "Warning",
    "AzureFunctionsJobHost__logging__logLevel__Worker": "Warning",
    "AzureFunctionsJobHost__logging__logLevel__Host": "Warning",
    "AzureFunctionsJobHost__logging__logLevel__Microsoft": "Warning",
    "AzureFunctionsJobHost__logging__logLevel__function_app": "Information",
    "AzureFunctionsJobHost__logging__logLevel__handlers.receipt_handler": "Information",
